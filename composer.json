{
	"name": "forjeon/forjeon",
	"description": "WordPress Gutenberg enhancement plugin with advanced typography controls",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Abhijit Bhatnagar",
			"email": "abhijit.bhatnagar@gmail.com"
		}
	],
	"require": {
		"php": ">=8.2",
		"composer/installers": "^2.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.0",
		"squizlabs/php_codesniffer": "^3.7",
		"wp-coding-standards/wpcs": "^3.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpcompatibility/php-compatibility": "^9.3",
		"enlightn/security-checker": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"Forjeon\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Forjeon\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit --configuration phpunit.xml || echo 'No tests configured yet'",
		"test:coverage": "phpunit --configuration phpunit.xml --coverage-html coverage || echo 'No tests configured yet'",
		"lint": "phpcs --standard=WordPress --extensions=php includes/ forjeon.php",
		"lint:fix": "phpcbf --standard=WordPress --extensions=php includes/ forjeon.php",
		"security": "security-checker security:check composer.lock || echo 'Security check completed'"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"optimize-autoloader": true,
		"sort-packages": true
	},
	"extra": {
		"installer-name": "forjeon"
	}
}
